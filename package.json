{
  "name": "lpf-2026",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --filter lpf-2026-web dev",
    "build": "bun --filter lpf-2026-web build",
    "preview": "bun --filter lpf-2026-web preview",
    "type-check": "bun --filter lpf-2026-web type-check",
    "format": "bun --filter lpf-2026-web format",
    "prepare": "vp config"
  },
  "devDependencies": {
    "typescript": "~6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.4",
    "vite-plus": "latest"
  },
  "overrides": {
    "@vue/compat": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9",
    "vue": "beta"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
