{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "happo-sai-status",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "happo-sai-status",
      // wrangler d1 create happo-sai-status の出力で置き換える
      "database_id": "fc18c3cd-3601-40c3-802d-e989264e948a",
    },
  ],
}
